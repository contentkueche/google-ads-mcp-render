      "annotations": {
        "readOnlyHint": true
      },
      "description": "Audit campaign budgets for common budget pitfalls.\n\nFlags shared budgets, daily costs that exceed 2x average daily budget,\nprojected monthly spend above a caller-provided cap, and spend with no\nconversions. This tool only reads Google Ads data.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "customer_id": {
            "description": "The Google Ads customer ID.",
            "type": "string"
          },
          "limit": {
            "default": 1000,
            "description": "Maximum GAQL rows to inspect.",
            "type": "integer"
          },
          "lookback_days": {
            "default": 7,
            "description": "Number of recent days to inspect, from 1 to 30.",
            "type": "integer"
          },
          "min_wasted_cost_micros": {
            "default": 10000000,
            "description": "Minimum lookback cost before no-conversion spend is flagged.",
            "type": "integer"
          },
          "monthly_spend_cap_amount_micros": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Optional account or portfolio spend cap."
          },
          "only_enabled": {
            "default": true,
            "description": "Whether to inspect only enabled campaigns.",
            "type": "boolean"
          }
        },
        "required": [
          "customer_id"
        ],
        "type": "object"
      },
      "name": "budget_audit_budget_pitfalls",
      "outputSchema": {
        "properties": {
          "result": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "result"
        ],
        "type": "object",
        "x-fastmcp-wrap-result": true
      }
    },
